<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100">
  <!-- Red lobster body -->
  <ellipse cx="50" cy="50" rx="30" ry="25" fill="#FF4500"/>
  <!-- Claws -->
  <ellipse cx="30" cy="40" rx="12" ry="8" fill="#FF4500"/>
  <ellipse cx="70" cy="40" rx="12" ry="8" fill="#FF4500"/>
  <!-- Legs -->
  <rect x="25" y="70" width="6" height="15" fill="#FF4500"/>
  <rect x="35" y="72" width="6" height="13" fill="#FF4500"/>
  <rect x="45" y="73" width="6" height="12" fill="#FF4500"/>
  <rect x="55" y="73" width="6" height="12" fill="#FF4500"/>
  <rect x="65" y="72" width="6" height="13" fill="#FF4500"/>
  <rect x="75" y="70" width="6" height="15" fill="#FF4500"/>
  <!-- Eyes -->
  <circle cx="45" cy="45" r="5" fill="white"/>
  <circle cx="55" cy="45" r="5" fill="white"/>
  <circle cx="45" cy="45" r="2" fill="black"/>
  <circle cx="55" cy="45" r="2" fill="black"/>
  <!-- Mouth -->
  <path d="M45 55 Q50 60 55 55" stroke="black" stroke-width="2" fill="none"/>
</svg>
