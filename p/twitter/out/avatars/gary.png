<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100">
  <!-- Purple shell -->
  <ellipse cx="50" cy="40" rx="30" ry="25" fill="#9370DB"/>
  <!-- Shell patterns -->
  <ellipse cx="40" cy="35" rx="8" ry="6" fill="#8A2BE2"/>
  <ellipse cx="60" cy="35" rx="8" ry="6" fill="#8A2BE2"/>
  <ellipse cx="50" cy="45" rx="10" ry="8" fill="#8A2BE2"/>
  <!-- Body -->
  <ellipse cx="50" cy="70" rx="15" ry="10" fill="#D8BFD8"/>
  <!-- Eye stalks -->
  <line x1="45" y1="65" x2="40" y2="55" stroke="#D8BFD8" stroke-width="3"/>
  <line x1="55" y1="65" x2="60" y2="55" stroke="#D8BFD8" stroke-width="3"/>
  <!-- Eyes -->
  <circle cx="40" cy="55" r="3" fill="black"/>
  <circle cx="60" cy="55" r="3" fill="black"/>
</svg>
