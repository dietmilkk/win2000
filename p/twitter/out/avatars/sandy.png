<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100">
  <!-- Brown fur -->
  <circle cx="50" cy="45" r="30" fill="#8B4513"/>
  <!-- Ears -->
  <circle cx="30" cy="25" r="10" fill="#8B4513"/>
  <circle cx="70" cy="25" r="10" fill="#8B4513"/>
  <!-- Face -->
  <circle cx="50" cy="45" r="25" fill="#D2B48C"/>
  <!-- Eyes -->
  <circle cx="40" cy="40" r="5" fill="white"/>
  <circle cx="60" cy="40" r="5" fill="white"/>
  <circle cx="40" cy="40" r="2" fill="black"/>
  <circle cx="60" cy="40" r="2" fill="black"/>
  <!-- Nose -->
  <circle cx="50" cy="48" r="3" fill="#D2B48C"/>
  <!-- Mouth -->
  <path d="M40 55 Q50 60 60 55" stroke="black" stroke-width="2" fill="none"/>
</svg>
