<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100">
  <!-- Red crab body -->
  <ellipse cx="50" cy="50" rx="35" ry="25" fill="#DC143C"/>
  <!-- Legs -->
  <rect x="25" y="70" width="8" height="15" fill="#DC143C"/>
  <rect x="35" y="72" width="8" height="13" fill="#DC143C"/>
  <rect x="45" y="73" width="8" height="12" fill="#DC143C"/>
  <rect x="55" y="73" width="8" height="12" fill="#DC143C"/>
  <rect x="65" y="72" width="8" height="13" fill="#DC143C"/>
  <rect x="75" y="70" width="8" height="15" fill="#DC143C"/>
  <!-- Eyes -->
  <circle cx="45" cy="40" r="8" fill="white"/>
  <circle cx="55" cy="40" r="8" fill="white"/>
  <circle cx="45" cy="40" r="4" fill="black"/>
  <circle cx="55" cy="40" r="4" fill="black"/>
  <!-- Eyebrows -->
  <path d="M40 30 Q45 25 50 30" stroke="black" stroke-width="2" fill="none"/>
  <path d="M50 30 Q55 25 60 30" stroke="black" stroke-width="2" fill="none"/>
  <!-- Mouth -->
  <path d="M45 50 Q50 55 55 50" stroke="black" stroke-width="2" fill="none"/>
</svg>
