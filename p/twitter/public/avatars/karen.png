<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100">
  <!-- Gray computer body -->
  <rect x="30" y="30" width="40" height="40" rx="5" fill="#808080"/>
  <!-- Screen -->
  <rect x="35" y="35" width="30" height="25" fill="#000000"/>
  <!-- Screen content -->
  <circle cx="50" cy="45" r="5" fill="#00FF00"/>
  <path d="M40 55 L60 55" stroke="#00FF00" stroke-width="2"/>
  <!-- Buttons -->
  <circle cx="40" cy="65" r="3" fill="#A9A9A9"/>
  <circle cx="50" cy="65" r="3" fill="#A9A9A9"/>
  <circle cx="60" cy="65" r="3" fill="#A9A9A9"/>
</svg>
