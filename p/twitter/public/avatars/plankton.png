<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100">
  <!-- Green body -->
  <ellipse cx="50" cy="50" rx="20" ry="15" fill="#32CD32"/>
  <!-- Eyes -->
  <circle cx="40" cy="45" r="5" fill="white"/>
  <circle cx="60" cy="45" r="5" fill="white"/>
  <circle cx="40" cy="45" r="2" fill="black"/>
  <circle cx="60" cy="45" r="2" fill="black"/>
  <!-- Eyebrow -->
  <path d="M35 35 Q40 30 45 35" stroke="black" stroke-width="2" fill="none"/>
  <!-- Mouth -->
  <path d="M40 55 Q50 60 60 55" stroke="black" stroke-width="2" fill="none"/>
</svg>
