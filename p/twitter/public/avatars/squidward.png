<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100">
  <!-- Light blue head -->
  <ellipse cx="50" cy="40" rx="30" ry="35" fill="#ADD8E6"/>
  <!-- Body -->
  <rect x="35" y="70" width="30" height="20" fill="#ADD8E6"/>
  <!-- Eyes -->
  <ellipse cx="40" cy="35" rx="8" ry="12" fill="white"/>
  <ellipse cx="60" cy="35" rx="8" ry="12" fill="white"/>
  <circle cx="40" cy="35" r="3" fill="black"/>
  <circle cx="60" cy="35" r="3" fill="black"/>
  <!-- Nose -->
  <path d="M50 45 L45 50 L55 50 Z" fill="#87CEEB"/>
  <!-- Mouth -->
  <path d="M45 60 Q50 65 55 60" stroke="black" stroke-width="2" fill="none"/>
</svg>
